# ─── BigQuery ────────────────────────────────────────────────
# ID del proyecto de GCP
GCP_PROJECT_ID=mi-proyecto-gcp

# Dataset y tabla de liquidaciones
BQ_DATASET=liquidaciones_logistic
BQ_TABLE=pedidos          # nombre de la tabla/vista dentro del dataset

# Credenciales de la service account (JSON en una sola línea, o pega la key en base64)
# Opción A — JSON raw (recomendado en local)
GCP_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"..."}

# Opción B — archivo .json (solo local, NO subir a Vercel)
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json


# ─── Google Sheets (tareo) ────────────────────────────────────
# ID del Google Sheet (parte de la URL: /spreadsheets/d/<ID>/edit)
SHEETS_SPREADSHEET_ID=1A2B3C4D5E6F...

# Nombre o rango de la pestaña del tareo
SHEETS_TAREO_RANGE=Turnos driver!A1:H500

# Misma service account que BigQuery (reutiliza GCP_SERVICE_ACCOUNT_JSON)
# Asegúrate de compartir el Sheet con el email de la service account (client_email)
